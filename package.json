{
  "name": "ggai-stella-engine",
  "version": "0.0.17",
  "description": "NovelAI 스토리텔러 스타일의 소설 생성 옵시디언 플러그인 (GGAI Core 기반)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "test:harness": "node scripts/run-harness.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "release": "npm run build && node scripts/release.mjs",
    "deploy": "npm run release && node scripts/deploy.mjs"
  },
  "keywords": [],
  "author": "gg00",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.0",
    "obsidian": "1.5.7-1",
    "tslib": "2.6.2",
    "typescript": "5.3.3"
  }
}
